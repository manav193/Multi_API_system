NODE_ENV=production
GEMINI_API_KEY=
APP_URL=https://your-domain.example
ALLOWED_ORIGINS=https://your-domain.example
TRUST_PROXY=false
ALLOW_IN_MEMORY_STORE=false
SECURE_COOKIES=true

# SECURITY & CONFIGURATION EXPLANATIONS:
# -----------------------------------------------------------------------------
# - ALLOW_IN_MEMORY_STORE=true is permitted only for an explicitly accepted single-instance deployment.
# - TRUST_PROXY must be configured for the actual hosting proxy topology and must never be blindly enabled.
# - Horizontally scaled production requires the Redis implementations.
